# API must be reachable from the device. For a phone on Wi‑Fi, use your PC's LAN IP, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# Web app origin for share links and QR (Vite dev server is often 5173; production = your site URL)
EXPO_PUBLIC_WEB_ORIGIN=http://localhost:5173
