# Dev server port (default 3000). If "address already in use", set PORT=3001 or stop the other process.
# PORT=3000

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URI (Supabase → Project Settings → Database → Connection string → URI).
# Enables automatic custom_fields migration on server start and npm run migrate:custom-fields.
# DATABASE_URL=
# SUPABASE_DB_URL=

# JWT Configuration
JWT_SECRET=
PASSWORD_RESET_SECRET=

# Public base URL used in password reset email links.
PUBLIC_APP_URL=https://sheepmug.com

# Optional API origin for web app when frontend and backend are deployed separately.
# Example: VITE_API_BASE_URL=https://api.sheepmug.com
# VITE_API_BASE_URL=

# Brevo transactional email (forgot/reset password).
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@sheepmug.com
BREVO_FROM_NAME=SheepmugCMS

# Comma-separated staff emails that may access /api/superadmin/* if profiles.is_super_admin is not set yet.
# SUPERADMIN_EMAILS=you@example.com

# Grace period before low-attendance "member needs follow-up" automation starts for new members.
# MEMBER_CARE_NEW_MEMBER_GRACE_DAYS=30

